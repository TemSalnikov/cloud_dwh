# Конфигурация node1 (192.168.31.195)
# Этот файл читают скрипты bootstrap.sh, build-images.sh и др.

# --- Сервер ---
SERVER_IP=192.168.31.195
HOSTNAME=node1
SERVER_USER=user
KUBE_API=https://192.168.31.195:6443

# --- Домены (nip.io резолвит *.192.168.31.195.nip.io → 192.168.31.195) ---
BASE_DOMAIN=192.168.31.195.nip.io

# --- Путь к проекту на node1 ---
REPO_DIR=/home/user/dev/cloud_dwh

# --- Kubernetes ---
KUBECONFIG=/etc/kubernetes/admin.conf

# --- Локальный Docker registry (образы platform-api/ui) ---
REGISTRY=192.168.31.195:5000

# --- URL после установки (открывать в браузере с любой машины в сети) ---
PLATFORM_UI=https://platform.192.168.31.195.nip.io
GRAFANA=https://grafana.192.168.31.195.nip.io

# --- Инструменты (устанавливаются setup-node1.sh на node1) ---
# kubectl  → /usr/local/bin/kubectl   управление K8s
# helm     → /usr/local/bin/helm      деплой charts
# docker   → /usr/bin/docker          сборка образов
# registry → 192.168.31.195:5000      хранение образов
