# Зафиксированные версии Helm charts и manifests для offline-установки
# Обновление: bash scripts/download-vendor.sh (на машине с интернетом)

# Helm charts
CHART_INGRESS_NGINX=ingress-nginx/ingress-nginx:4.15.1
CHART_CERT_MANAGER=jetstack/cert-manager:v1.16.2
CHART_STRIMZI=strimzi/strimzi-kafka-operator:0.48.0
CHART_CNPG=cnpg/cloudnative-pg:0.23.2
CHART_PROMETHEUS=prometheus-community/kube-prometheus-stack:67.5.0

# Helm repos
REPO_INGRESS_NGINX=https://kubernetes.github.io/ingress-nginx
REPO_JETSTACK=https://charts.jetstack.io
REPO_STRIMZI=https://strimzi.io/charts/
REPO_CNPG=https://cloudnative-pg.github.io/charts
REPO_PROMETHEUS=https://prometheus-community.github.io/helm-charts

# Kubectl manifests (URLs → локальные файлы в deploy/vendor/manifests/)
MANIFEST_LOCAL_PATH=https://raw.githubusercontent.com/rancher/local-path-provisioner/v0.0.28/deploy/local-path-storage.yaml
MANIFEST_CLICKHOUSE_OP=https://raw.githubusercontent.com/Altinity/clickhouse-operator/master/deploy/operator/clickhouse-operator-install-bundle.yaml
